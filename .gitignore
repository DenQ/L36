# --- Бинарные файлы (результаты сборки L-36) ---
l36-server
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# --- Данные (хранилища 36 шардов) ---
# Игнорируем папку с логами и дампами, чтобы не забить гит гигабайтами
data/
*.log
*.dump
*.db

# --- Конфигурация и секреты ---
.env
configs/*.local.yaml

# --- Зависимости и инструменты ---
vendor/
.idea/
.vscode/
*.swp
*.bak

# --- Логи самого приложения (не путать с данными шардов) ---
logs/
*.out
*.err

# --- Тесты ---
coverage.out
